{
  "name": "@taskgenie/api",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/worker.ts src/db/migrate.ts src/db/seed.ts src/db/rescan-attachments.ts --format esm --platform node --target node22 --sourcemap --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "start:worker": "node dist/worker.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:rescan-attachments": "tsx src/db/rescan-attachments.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/websocket": "^11.3.0",
    "@node-rs/argon2": "2.0.2",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "iovalkey": "0.3.3",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
