NODE_ENV=production
HOST=0.0.0.0
PORT=4000
WEB_PORT=3000
LOG_LEVEL=info
TASKGENIE_DOMAIN=tasks.example.com

POSTGRES_DB=taskgenie
POSTGRES_USER=taskgenie
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://taskgenie:replace-with-a-long-random-password@postgres:5432/taskgenie
DATABASE_POOL_MAX=10

VALKEY_PASSWORD=replace-with-a-long-random-password
VALKEY_URL=redis://:replace-with-a-long-random-password@valkey:6379/0
VALKEY_KEY_PREFIX=taskgenie:

BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
BETTER_AUTH_URL=https://tasks.example.com
CORS_ORIGINS=https://tasks.example.com
COOKIE_SECURE=true
REQUIRE_EMAIL_VERIFICATION=false

RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760

# Browser uses the same origin through Caddy. Leave empty for Docker production.
NEXT_PUBLIC_API_URL=
# Used by Next.js dev/server rewrites.
API_INTERNAL_URL=http://api:4000
# Real-time collaboration (authenticated WebSockets)
REALTIME_ENABLED=true
REALTIME_MAX_PAYLOAD_BYTES=65536
REALTIME_HEARTBEAT_MS=30000
REALTIME_MESSAGES_PER_MINUTE=120
# Leave empty in same-origin Docker production. Set ws://localhost:4000 for unusual dev setups.
NEXT_PUBLIC_WS_URL=

# ClamAV upload scanning. Production should remain fail-closed.
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000
CLAMAV_CHUNK_BYTES=65536
CLAMAV_FAIL_OPEN=false

